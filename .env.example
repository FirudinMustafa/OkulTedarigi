# ============================================================
# Okul Tedarik Sistemi - Environment Variables
# ============================================================
# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun:
#   cp .env.example .env
#
# PRODUCTION'da: Vercel Dashboard > Settings > Environment Variables
# kismindan ekleyin. .env dosyasini ASLA commit etmeyin.
# ============================================================

# ============================================================
# Database (MySQL / MySQL-uyumlu)
# ============================================================
# Local development:
#   docker-compose up -d  (sonra DATABASE_URL aşağıdaki gibi)
#   DATABASE_URL="mysql://okul_user:okul_pass_2024@localhost:3306/okul_tedarik"
#
# Production (TiDB Cloud — onerilen):
#   1. https://tidbcloud.com'da "Serverless" cluster olustur (free tier var)
#   2. Cluster > Connect > Connection String'i al
#   3. Yeni bir database olustur (default 'sys' KULLANMA — bu sistem DB'sidir):
#        CREATE DATABASE okul_tedarik;
#   4. Connection string formati:
#        mysql://<USER>:<PASSWORD>@gateway01.eu-central-1.prod.aws.tidbcloud.com:4000/okul_tedarik?sslaccept=strict
#
# ÖNEMLI:
#   - "sslaccept=strict" zorunlu (TiDB Cloud TLS gerektirir).
#   - Sifreyi ASLA .env veya kaynak koda commit etmeyin.
#     Production'da Vercel Dashboard > Environment Variables uzerinden ekleyin.
#   - Database adi 'sys' DEGIL, kendi olusturdugunuz (orn. 'okul_tedarik') olmalidir.
#
# Diger production secenekleri: PlanetScale, AWS RDS, Aiven, DigitalOcean Managed MySQL
DATABASE_URL="mysql://USER:PASSWORD@gateway01.eu-central-1.prod.aws.tidbcloud.com:4000/okul_tedarik?sslaccept=strict"

# ============================================================
# JWT Authentication
# ============================================================
# PRODUCTION'da MUTLAKA guclu bir secret kullanin.
# Olusturmak icin terminalde:  openssl rand -base64 32
# Asagidaki "dev-secret..." veya benzer zayif degerler runtime'da reddedilir.
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# ============================================================
# Initial Admin (prisma db seed icin gerekli)
# ============================================================
# `npx prisma db seed` calistirildiginda admin hesabi olusturulur.
# ADMIN_PASSWORD en az 12 karakter olmalidir.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Sistem Yoneticisi"

# ============================================================
# Application URL
# ============================================================
# Email template'lerindeki link'lerde kullanilir.
# Production'da gercek domain olmalidir (https://okultedarigim.com).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Okul Tedarik Sistemi"

# ============================================================
# Mock API Flags
# ============================================================
# Default: KAPALI. Sadece "true" stringi mock'u acar.
# Mock = entegrasyon olmadan calisir (gercek API'ye istek gitmez).
#
# Bu projede mock'lar: ODEME, FATURA, KARGO, EMAIL, SMS
# Asagidaki flag'ler "true" ise simulasyon, "false" / bos ise gercek API.
#
# PRODUCTION'da: API anahtarlari elinize ulastiginda flag'i kaldirin
# veya bos birakin. Suanki entegrasyon eksikse "true" tutmak NORMAL.
# ============================================================
USE_MOCK_PAYMENT="true"
USE_MOCK_INVOICE="true"
USE_MOCK_CARGO="true"
USE_MOCK_EMAIL="true"
USE_MOCK_SMS="true"

# ============================================================
# Iyzico Payment Gateway
# ============================================================
# Mock=true iken bu degerler kullanilmaz.
# Gercek entegrasyonda: Iyzico Checkout Form (hosted) tercih edin.
# Kart bilgileri ASLA backend'inize gonderilmemelidir (PCI-DSS).
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
# Production: https://api.iyzipay.com

# ============================================================
# KolayBi E-Fatura (https://kolaybi.com)
# ============================================================
# Test/Sandbox URL: https://ofis-sandbox-api.kolaybi.com
# Production URL : https://ofis-api.kolaybi.com
#
# ENTEGRASYON SIRASI (zorunlu):
#   1. Sandbox API key'i KolayBi panelinizden alin (Ayarlar > Hesap > API Keys)
#   2. Channel bilginiz icin api.support@kolaybi.com'a yazin
#   3. Sandbox'ta tum fatura akisini test edin (kesim, iptal, durum)
#   4. Production URL + production API key'e gecin
#
# Auth flow:
#   POST /kolaybi/v1/access_token  Headers: Channel, Body: {"api_key": "..."}
#   Response: { "data": "JWT" } (24 saat gecerli)
KOLAYBI_BASE_URL="https://ofis-sandbox-api.kolaybi.com"
KOLAYBI_API_KEY=""
KOLAYBI_CHANNEL=""
# Geriye uyumluluk: eski entegrasyonda KOLAYBI_SECRET_KEY varsa kabul edilir.
KOLAYBI_SECRET_KEY=""

# ============================================================
# Aras Kargo
# ============================================================
ARAS_CUSTOMER_CODE=""
ARAS_PASSWORD=""

# ============================================================
# Resend Email Service (https://resend.com)
# ============================================================
# EMAIL_FROM domain'inin Resend'de dogrulanmis olmasi gerekir.
RESEND_API_KEY=""
EMAIL_FROM="noreply@okultedarigim.com"

# ============================================================
# Twilio SMS Service (https://twilio.com)
# ============================================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================================
# Google Gemini AI (Chatbot - opsiyonel)
# ============================================================
GEMINI_API_KEY=""

# ============================================================
# Docker / MySQL (sadece local development icin)
# ============================================================
# Production'da KULLANMAYIN. Vercel deploy'da bu degiskenler degil
# DATABASE_URL kullanilir.
MYSQL_ROOT_PASSWORD=""
MYSQL_DATABASE="okul_tedarik"
MYSQL_USER="okul_user"
MYSQL_PASSWORD=""
MYSQL_PORT="3306"
